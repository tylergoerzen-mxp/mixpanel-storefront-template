# ---------------------------------------------------------------------------
# Mixpanel Storefront — environment variables
# ---------------------------------------------------------------------------
# If you scaffolded this with `stripe projects build`, every variable in the
# "Provided by Stripe Projects" sections below is injected automatically by the
# linked provider — you do NOT need to fill them in. Run `stripe projects env`
# to view them (redacted) or `stripe projects env --pull` to write a local .env.
#
# The app runs with ZERO configuration: with no env vars set it serves the
# bundled product catalog and runs checkout in demo mode. Add the providers
# below to light up live analytics, a real database, and real payments.
# ---------------------------------------------------------------------------

# === Mixpanel — provided by Stripe Projects (mixpanel/analytics) ============
# MIXPANEL_PROJECT_TOKEN is the only one the storefront strictly needs to start
# streaming events. The others are injected by the provider and used for
# server-side ingestion / admin tooling.
MIXPANEL_PROJECT_TOKEN=
MIXPANEL_INGESTION_URL=
MIXPANEL_API_URL=
MIXPANEL_PROJECT_ID=
MIXPANEL_SERVICE_ACCOUNT_USERNAME=
MIXPANEL_SERVICE_ACCOUNT_SECRET=

# === Supabase — provided by Stripe Projects (supabase/project) ==============
# Optional. When set, the storefront reads its product catalog from the
# `products` table instead of the bundled seed. See supabase/migrations.
SUPABASE_PROJECT_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_DB_URL=

# === Vercel — provided by Stripe Projects (vercel/project) ==================
# Used by `pnpm deploy` (vercel deploy). Not read at runtime by the app.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# === Stripe Checkout — OPTIONAL, set manually ===============================
# Leave blank to run checkout in demo mode (no charge, still fires the
# "Order Completed" revenue event into Mixpanel). Add your Stripe test keys
# from https://dashboard.stripe.com/test/apikeys to enable real Checkout.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Base URL used to build Stripe Checkout success/cancel redirect links.
# Defaults to http://localhost:3000 in dev and the Vercel URL in prod.
NEXT_PUBLIC_SITE_URL=
